    "ask": [
      "Bash(curl:*)",
      "Bash(rm:*)",
      "Read(~/**)",
      "Github.com/github/github-mcp-server",
      "mcp__github_com_github_github-mcp-server__get_me",
      "mcp__github_com_github_github-mcp-server__pull_request_read",
