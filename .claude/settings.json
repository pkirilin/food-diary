      "Bash(git branch:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git remote get-url:*)",
      "Bash(git status:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(rg:*)",
